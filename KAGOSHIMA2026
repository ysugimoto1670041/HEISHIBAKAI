    <!-- AI用スクリプト -->
    <script>
        const apiKey = ""; // API key is provided by the execution environment
        const chatMessages = document.getElementById('chat-messages');
        const aiInput = document.getElementById('ai-input');
        const quickPrompts = document.getElementById('quick-prompts');

        function toggleAIChat() {
            const chatPanel = document.getElementById('ai-chat-panel');
            const toggleBtn = document.getElementById('ai-toggle-btn');
            if (chatPanel.classList.contains('hidden')) {
                chatPanel.classList.remove('hidden');
                toggleBtn.classList.add('hidden');
                aiInput.focus();
            } else {
                chatPanel.classList.add('hidden');
                toggleBtn.classList.remove('hidden');
            }
        }

        function sendAIQuery(text) {
            aiInput.value = text;
            sendUserMessage();
            if(quickPrompts) quickPrompts.classList.add('hidden');
        }

        async function sendUserMessage() {
            const text = aiInput.value.trim();
            if (!text) return;

            appendMessage(text, 'user');
            aiInput.value = '';
            const loadingId = appendLoading();

            try {
                const responseText = await fetchGeminiResponse(text);
                removeElement(loadingId);
                appendMessage(responseText, 'ai');
            } catch (error) {
                console.error("Gemini API Error:", error);
                removeElement(loadingId);
                appendMessage("ごめんなさい、ちょっと考えすぎてしまいました💦 もう一度質問してみていただけますか？", 'error');
            }
        }

        async function fetchGeminiResponse(userText) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text: userText }] }],
                systemInstruction: {
                    parts: [{ text: "あなたは「平芝会鹿児島ツアー」の専属AIコンシェルジュです。日程は3月26日(木)〜27日(金)で、ゴルフ場は「溝辺カントリークラブ」「指宿ゴルフクラブ」、宿泊は「指宿白水館」です。参加者からの質問に、フレンドリーで親切なトーンで絵文字を交え簡潔に回答してください。" }]
                }
            };

            let retries = 5;
            let delay = 1000;
            
            for (let i = 0; i < retries; i++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    
                    if (!response.ok) throw new Error(`HTTP error: ${response.status}`);
                    const data = await response.json();
                    return data.candidates[0].content.parts[0].text;
                } catch (error) {
                    if (i === retries - 1) throw error;
                    await new Promise(res => setTimeout(res, delay));
                    delay *= 2;
                }
            }
        }

        function appendMessage(text, sender) {
            const wrapper = document.createElement('div');
            wrapper.className = `flex items-start gap-2 mt-3 ${sender === 'user' ? 'justify-end' : ''}`;
            
            const bubble = document.createElement('div');
            if (sender === 'user') {
                bubble.className = 'bg-emerald-600 text-white p-3 rounded-xl rounded-tr-none shadow-sm text-sm max-w-[85%] leading-relaxed';
                bubble.textContent = text;
            } else {
                bubble.className = `bg-white border p-3 rounded-xl rounded-tl-none shadow-sm text-sm text-gray-800 max-w-[90%] leading-relaxed ${sender === 'error' ? 'border-red-300 bg-red-50' : 'border-gray-200'}`;
                let formattedText = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>');
                bubble.innerHTML = formattedText;
            }
            
            wrapper.appendChild(bubble);
            chatMessages.appendChild(wrapper);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function appendLoading() {
            const id = 'loading-' + Date.now();
            const wrapper = document.createElement('div');
            wrapper.id = id;
            wrapper.className = 'flex items-start gap-2 mt-3';
            wrapper.innerHTML = `
                <div class="bg-white border border-gray-200 p-3 rounded-xl rounded-tl-none shadow-sm flex items-center gap-1.5">
                    <div class="w-2 h-2 bg-emerald-400 rounded-full animate-bounce"></div>
                    <div class="w-2 h-2 bg-emerald-500 rounded-full animate-bounce" style="animation-delay: 0.1s"></div>
                    <div class="w-2 h-2 bg-emerald-600 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
                </div>
            `;
            chatMessages.appendChild(wrapper);
            chatMessages.scrollTop = chatMessages.scrollHeight;
            return id;
        }

        function removeElement(id) {
            const el = document.getElementById(id);
            if (el) el.remove();
        }
    </script>
</body>
</html>
